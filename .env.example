# Copy to .env and adjust values. Flask loads this via python-dotenv in app.py.

# Required in production (Render): set a long random string
SECRET_KEY=change-me-to-a-long-random-string

# Optional: PostgreSQL (Render sets DATABASE_URL automatically when you add Postgres)
# Leave unset to use SQLite file ./instance/attendance.db locally
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# If someone registers with this exact value in the "Admin secret" field, they become admin.
# Leave empty to disable admin self-registration (then use: flask --app app create-admin)
ADMIN_REGISTRATION_SECRET=myadmin123

# Browser session lifetime (minutes) — idle security / "session timeout"
SESSION_TIMEOUT_MINUTES=60

# How long a QR code remains valid after the timestamp embedded in it (seconds)
QR_VALIDITY_SECONDS=300

